# =====================================================
# AegisAI Backend Environment Variables
# Copy this file to `.env` and fill in real values.
# NEVER commit .env to git.
# =====================================================

# Server
PORT=5000
NODE_ENV=development

# Supabase (get these from Supabase Dashboard > Project Settings > API)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# HuggingFace Inference API
# Get a token at https://huggingface.co/settings/tokens (read access is enough)
HF_API_TOKEN=hf_your_token_here
HF_MODEL=imanoop7/bert-phishing-detector

# Phishing classification threshold (0.0 - 1.0)
PHISHING_THRESHOLD=0.7

# CORS - allow your Chrome extension ID once you have it
# In dev you can leave as * or set to chrome-extension://YOUR_EXTENSION_ID
ALLOWED_ORIGINS=*
